# ── Langfuse (self-hosted via docker-compose) ─────────────────────────────────
#
# How to get these keys:
#   1. docker compose up -d
#   2. Open http://localhost:3000 → sign up → create a project
#   3. Settings → API Keys → create a key pair
#   4. Paste the values below
#
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# ── Arize Phoenix ─────────────────────────────────────────────────────────────
# Runs locally via docker-compose — no credentials needed.
# UI: http://localhost:6006
